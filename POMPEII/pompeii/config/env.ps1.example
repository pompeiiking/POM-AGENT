# Example PowerShell env script for local development (copy to config/env.ps1 or repo-root env.ps1).
#
# Usage:
# 1. Copy this file to config/env.ps1 (recommended) or env.ps1 at repo root — do not commit real keys.
# 2. Edit values below with your actual key.
# 3. Start services (recommended):
#      cd <pompeii repo root>
#      .\scripts\run-http.cmd
#
# 4. If ExecutionPolicy blocks dot-sourcing .ps1, in the same terminal (only if you trust the file):
#      Get-Content -Path .\config\env.ps1 -Raw | Invoke-Expression
#    Or for legacy root env.ps1:
#      Get-Content -Path .\env.ps1 -Raw | Invoke-Expression
#    Then:
#      $env:PYTHONPATH = "src"
#      python -m app.http_runtime
#
# Notes:
# - Do not commit config/env.ps1 or root env.ps1 with real secrets.
# - For servers or Docker, prefer injecting env vars instead of this script.

$env:DEEPSEEK_API_KEY = "your-deepseek-api-key-here"
